# go-backend/Dockerfile.dev
# Uses 'air' for hot-reload — file changes in ./go-backend/ restart the server automatically.

FROM golang:1.23-alpine

RUN apk add --no-cache curl git

# Install air (hot-reload)
RUN go install github.com/air-verse/air@latest

WORKDIR /app

# Cache dependencies layer — only re-downloads when go.mod/go.sum change
COPY go.mod go.sum ./
RUN go mod download

# air config is in .air.toml at the project root
COPY .air.toml .

EXPOSE 8080 2345

CMD ["air", "-c", ".air.toml"]